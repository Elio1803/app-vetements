# Required secrets. Pick an Anthropic Messages API model that supports vision.
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_MODEL=replace-with-a-vision-model-id

# Welcome email delivery. The sender domain must be verified by Resend.
RESEND_API_KEY=re_replace-me
WELCOME_FROM_EMAIL=Le Dressing <bonjour@example.com>

# remove.bg background removal. Keep this secret server-side only.
REMOVE_BG_API_KEY=replace-me

# AI visual try-on/composition. Keep FAL_API_KEY server-side only.
FAL_API_KEY=replace-me
TRYON_MODEL_IMAGE_URL=https://example.com/neutral-mannequin.jpg
FAL_TRYON_MODEL=fal-ai/fashn/tryon

# Comma-separated exact origins. Without this variable, only Vite localhost
# origins and non-browser requests are accepted. Use * only for local testing.
ALLOWED_ORIGINS=http://localhost:5173

# Optional, hard-clamped by the function (1..10).
MAX_OUTFIT_IMAGES=10

# Optional metadata candidate limit, hard-clamped by the function (10..100).
MAX_WARDROBE_CANDIDATES=60

# Optional cumulative raw-image budget, hard-clamped to 5..18 MiB so base64,
# metadata, and JSON remain below Anthropic's total request limit.
MAX_OUTFIT_IMAGE_BYTES_TOTAL=15728640
